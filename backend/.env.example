PORT=5000
NODE_ENV=development

# MongoDB Atlas — mongodb.com/atlas (free M0 cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/resumeforge

# JWT — run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRES_IN=7d

# Google Gemini (FREE) — aistudio.google.com/app/apikey
# Free tier: 15 req/min · 1M tokens/day · no credit card needed
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary — cloudinary.com (free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# Gmail App Password — myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Frontend URL
CLIENT_URL=http://localhost:5173
