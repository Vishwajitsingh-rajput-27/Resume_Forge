# ═══════════════════════════════════════════════════════════
# ResumeAI — Environment Variables
# Copy to .env and fill in your values.
# Free-tier keys only — no credit card required!
# ═══════════════════════════════════════════════════════════

# ── AI Provider ─────────────────────────────────────────────
# Options: GROQ | GEMINI | GROQ_FALLBACK
# GROQ_FALLBACK tries Groq first, falls back to Gemini if it fails
AI_PROVIDER=GROQ_FALLBACK

# ── Groq (Free) ──────────────────────────────────────────────
# Sign up free at https://console.groq.com → API Keys
# Free limits: 14,400 requests/day, no credit card needed
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model for regular tasks (fast, 30K tokens/min free)
GROQ_MODEL=llama-3.1-8b-instant

# Model for high-quality tasks (cover letters, interview Qs)
GROQ_QUALITY_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (Free) ──────────────────────────────────────
# Sign up free at https://aistudio.google.com → Get API Key
# Free limits: gemini-1.5-flash = 15 RPM / 1,500,000 TPD
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model for regular tasks
GEMINI_MODEL=gemini-1.5-flash

# Model for high-quality tasks
GEMINI_QUALITY_MODEL=gemini-1.5-pro

# ── Database ─────────────────────────────────────────────────
# Free at https://www.mongodb.com/cloud/atlas (M0 cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/resumeai?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Cloudinary (Free) ─────────────────────────────────────────
# Free at https://cloudinary.com — 25GB storage, 25GB bandwidth/month
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer) ────────────────────────────────────────
# Free: use Gmail with App Password or Brevo (300 emails/day free)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="ResumeAI <noreply@resumeai.app>"

# ── Google OAuth ──────────────────────────────────────────────
# Free at https://console.cloud.google.com
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Frontend (Next.js — prefix with NEXT_PUBLIC_) ─────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_32_char_random_string
NEXTAUTH_URL=http://localhost:3000
